<!DOCTYPE html><html lang="en"><head>    <meta charset="UTF-8">    <meta name="viewport" content="width=device-width, initial-scale=1.0">    <title>Admin Login</title>    <link rel="stylesheet" href="/css/styles.css"></head><body>    <div class="container-center">        <div class="card">            <h2>Admin Login</h2>            <p style="color: var(--muted); margin-bottom: 16px;">System Administrator</p>            <% if (error) { %>                <div class="alert alert-error"><%= error %></div>            <% } %>            <form method="post" action="/login">                <div class="form-row">                    <label for="email">Email</label>                    <input id="email" type="email" name="email" required autocomplete="email">                </div>                <div class="form-row">                    <label for="password">Password</label>                    <input id="password" type="password" name="password" required autocomplete="current-password">                </div>                <div class="form-row" style="margin-top: 10px;">                    <a class="link" href="/forgot-password">Forgot Password?</a>                </div>                <button class="primary" type="submit" style="width: 100%; margin-top: 18px;">Login</button>            </form>            <div style="margin-top: 16px; text-align: center; border-top: 1px solid var(--border); padding-top: 16px;">                <p style="color: var(--muted); font-size: 13px;">Student, Professor, or HOD?</p>                <a href="/user/login" class="link">User Login</a>            </div>        </div>    </div></body></html>
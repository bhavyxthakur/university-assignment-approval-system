<!DOCTYPE html><html lang="en"><head>    <meta charset="UTF-8">    <meta name="viewport" content="width=device-width, initial-scale=1.0">    <title>Student Dashboard</title>    <link rel="stylesheet" href="/css/styles.css"></head><body>    <%- include('studentNavigation') %>    <div class="main-with-sidebar">        <div class="container">            <h1>Dashboard</h1>            <p style="color:var(--muted);margin-top:6px">Welcome, <%= userName %></p>            <div class="stats-grid" style="margin-top: 20px;">                <div class="stat-card">                    <h5>Draft</h5>                    <h2><%= statusCounts.Draft || 0 %></h2>                </div>                <div class="stat-card">                    <h5>Submitted</h5>                    <h2><%= statusCounts.Submitted || 0 %></h2>                </div>                <div class="stat-card">                    <h5>Approved</h5>                    <h2><%= statusCounts.Approved || 0 %></h2>                </div>                <div class="stat-card">                    <h5>Rejected</h5>                    <h2><%= statusCounts.Rejected || 0 %></h2>                </div>                <div class="stat-card">                    <h5>Forwarded</h5>                    <h2><%= statusCounts.Forwarded || 0 %></h2>                </div>            </div>            <h2 style="margin-top: 24px;">Recent Submissions</h2>            <% if (recentSubmissions && recentSubmissions.length > 0) { %>                <table class="table">                    <thead>                        <tr>                            <th>Title</th>                            <th>Status</th>                            <th>Reviewer</th>                            <th>Submitted</th>                            <th>Actions</th>                        </tr>                    </thead>                    <tbody>                        <% recentSubmissions.forEach(function(assignment) { %>                            <tr>                                <td><%= assignment.title %></td>                                <td>                                    <span class="badge badge-<%= assignment.status.toLowerCase() %>">                                        <%= assignment.status %>                                    </span>                                </td>                                <td><%= assignment.reviewerId ? assignment.reviewerId.name : '-' %></td>                                <td><%= assignment.submittedAt ? assignment.submittedAt.toLocaleString() : '-' %></td>                                <td>                                    <a href="/student/assignments/<%= assignment._id %>/details" class="btn secondary">View</a>                                    <% if (assignment.status === 'Rejected') { %>                                        <a href="/student/assignments/<%= assignment._id %>/resubmit" class="btn info">Resubmit</a>                                    <% } else if (assignment.status === 'Draft') { %>                                        <a href="/student/assignments/<%= assignment._id %>/submit" class="btn primary">Submit</a>                                    <% } %>                                </td>                            </tr>                        <% }) %>                    </tbody>                </table>            <% } else { %>                <div class="card">                    <p style="color: var(--muted); text-align: center;">No assignments yet. <a href="/student/assignments/create" style="color: var(--accent);">Create your first assignment</a></p>                </div>            <% } %>            <% if (notifications && notifications.length > 0) { %>                <h2 style="margin-top: 24px;">Notifications</h2>                <div class="card">                    <% notifications.forEach(function(notif) { %>                        <div style="padding: 12px 0; border-bottom: 1px solid var(--border);">                            <strong><%= notif.title %></strong>                            <p style="margin: 4px 0; color: var(--muted); font-size: 13px;"><%= notif.message %></p>                            <small style="color: var(--muted);"><%= notif.createdAt.toLocaleString() %></small>                        </div>                    <% }) %>                </div>            <% } %>        </div>    </div></body></html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Professor Dashboard</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('professorNavigation') %>
    <div class="main-with-sidebar">
        <div class="container">
            <h1>Dashboard</h1>
            <p style="color:var(--muted);margin-top:6px">Welcome, <%= userName %></p>
            <div class="stats-grid" style="margin-top: 20px;">
                <div class="stat-card">
                    <h5>Pending Reviews</h5>
                    <h2><%= stats.pendingCount || 0 %></h2>
                </div>
                <div class="stat-card">
                    <h5>Total Reviewed</h5>
                    <h2><%= stats.totalReviewed || 0 %></h2>
                </div>
            </div>
            <h2 style="margin-top: 24px;">Pending Reviews</h2>
            <% if (pendingReviews && pendingReviews.length > 0) { %>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Assignment</th>
                            <th>Student</th>
                            <th>Category</th>
                            <th>Status</th>
                            <th>Days Pending</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% pendingReviews.forEach(function(assignment) { %>
                            <tr>
                                <td><%= assignment.title %></td>
                                <td><%= assignment.studentId ? assignment.studentId.name : '-' %></td>
                                <td><%= assignment.category %></td>
                                <td>
                                    <span class="badge badge-<%= assignment.status.toLowerCase() %>">
                                        <%= assignment.status %>
                                    </span>
                                </td>
                                <td>
                                    <% if (assignment.daysPending > 7) { %>
                                        <span style="color: #ef4444;"><%= assignment.daysPending %> days</span>
                                    <% } else { %>
                                        <%= assignment.daysPending %> days
                                    <% } %>
                                </td>
                                <td>
                                    <a href="/professor/assignments/<%= assignment._id %>/review" class="btn primary">Review</a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <div class="card">
                    <p style="color: var(--muted); text-align: center;">No pending reviews. Great job!</p>
                </div>
            <% } %>
            <% if (notifications && notifications.length > 0) { %>
                <h2 style="margin-top: 24px;">Notifications</h2>
                <div class="card">
                    <% notifications.forEach(function(notif) { %>
                        <div style="padding: 12px 0; border-bottom: 1px solid var(--border);">
                            <strong><%= notif.title %></strong>
                            <p style="margin: 4px 0; color: var(--muted); font-size: 13px;"><%= notif.message %></p>
                            <small style="color: var(--muted);"><%= notif.createdAt.toLocaleString() %></small>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>
